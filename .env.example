DATABASE_URL=sqlite:///./fantasy_role_ai.db
DATABASE_ECHO=false

STORAGE_PROVIDER=local
STORAGE_ENDPOINT_URL=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION=
STORAGE_PUBLIC_BASE_URL=
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_TYPES=pdf,docx,txt,png,jpg,jpeg
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

WECHAT_APPID=
WECHAT_SECRET=

LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=mock-model
LLM_API_STYLE=chat_completions
ENABLE_PROMPT_DEBUG=true
ENABLE_DEBUG_OUTPUT=true
LLM_TIMEOUT_SECONDS=30

SAFETY_MODE=rule
SAFETY_STRICT_LEVEL=normal
ENABLE_USER_DATA_DELETE=true
ENABLE_USER_DATA_EXPORT=true
PRIVACY_CONTACT_EMAIL=

OCR_PROVIDER=mock
OCR_LANG=ch
OCR_ENABLE_PDF_IMAGE_FALLBACK=false

IMAGE_PROVIDER=mock
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_MODEL=mock-image-model
IMAGE_TIMEOUT_SECONDS=60

# DeepSeek 示例
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=请填写你账号可用的模型名

# Kimi / Moonshot 示例
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.moonshot.ai/v1
# LLM_MODEL=请填写你账号可用的模型名

# 通义千问 / DashScope 示例
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=请填写 DashScope OpenAI compatible base_url
# LLM_MODEL=请填写你账号可用的模型名

# OCR 示例
# OCR_PROVIDER=paddleocr
# OCR_LANG=ch
# PaddleOCR 是可选依赖，未安装或不可用时会自动回退 MockOCRProvider。

# 图片生成示例
# IMAGE_PROVIDER=custom
# IMAGE_BASE_URL=请填写图片生成服务地址
# IMAGE_MODEL=请填写你账号可用的图片模型名
# IMAGE_API_KEY=只在本地 .env 填写，不要写入代码、文档或压缩包

# S3-compatible 存储示例
# STORAGE_PROVIDER=s3_compatible
# STORAGE_ENDPOINT_URL=请填写对象存储 endpoint
# STORAGE_BUCKET=请填写 bucket
# STORAGE_ACCESS_KEY_ID=只在本地 .env 填写，不要提交
# STORAGE_SECRET_ACCESS_KEY=只在本地 .env 填写，不要提交
# STORAGE_REGION=请填写 region
# STORAGE_PUBLIC_BASE_URL=请填写公开访问域名

# 自定义存储示例
# STORAGE_PROVIDER=custom
# 后续可按阿里云 OSS / 腾讯云 COS / 七牛等厂商 SDK 扩展

# 微信小程序登录预留
# WECHAT_APPID=只在部署环境填写，不要提交真实 appid
# WECHAT_SECRET=只在部署环境填写，不要提交真实 secret
